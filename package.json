{
  "name": "sehyeon-mall",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5188",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:host": "vite preview --host 0.0.0.0 --port 4173",
    "serve": "npm run build && serve dist --single --listen 4173 --no-port-switching --no-clipboard",
    "serve:vite": "npm run build && vite preview --host 0.0.0.0 --port 4173",
    "presentation:pdf": "node scripts/print-presentation-pdf.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "serve": "^14.2.4",
    "typescript": "~5.6.3",
    "vite": "^6.0.3"
  }
}
